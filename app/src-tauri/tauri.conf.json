{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "exfil",
  "version": "0.1.0",
  "identifier": "com.rangertaha.exfil.desktop",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "exfil",
        "width": 980,
        "height": 700,
        "minWidth": 640,
        "minHeight": 420
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:8080 http://localhost:8080 ipc: http://ipc.localhost; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
